# znative-config.cmake

# CMAKE_CURRENT_LIST_FILE
message(STATUS "CMAKE_CURRENT_LIST_FILE: ${CMAKE_CURRENT_LIST_FILE}")
get_filename_component(ZZZ_ROOT_DIR "${CMAKE_CURRENT_LIST_FILE}" DIRECTORY)
message(STATUS "ZZZ_ROOT_DIR: ${ZZZ_ROOT_DIR}")

include(${ZZZ_ROOT_DIR}/z-functions.cmake)
set(ZZZ_CMAKE_DIR ${ZZZ_ROOT_DIR}/cmake/${ZTARGET_ARCH})
set(ZZZ_INCLUDE_DIR ${ZZZ_ROOT_DIR}/include)
set(ZZZ_LIBS_DIR ${ZZZ_ROOT_DIR}/libs/${ZTARGET_ARCH})
set(ZZZ_PREBUILT_DIR ${ZZZ_ROOT_DIR}/prebuilt)

## libname cmake 的文件前缀名称 xxx-arm64-v8a-config.cmake
## 静默查找库, 并设置 ${find_result} 为 TRUE 或 FALSE
## find_path: 查找路径
## libname: 库名称
## find_result: 查找结果, 为 TRUE 或 FALSE
## usage:
## z_find_package_quiet( ${find_path} ${libname} FIND_RESULT)
function(z_find_package_quiet libname find_result)
    find_package(${libname} QUIET)
    if (TARGET ${libname})
        message(STATUS "found library: ${libname}")
        set(${find_result} TRUE PARENT_SCOPE)
    else ()
        message(STATUS "${libname} not found")
        set(${find_result} FALSE PARENT_SCOPE)
    endif ()
endfunction()

## 静默导入静态库
## find_path: 查找路径
## filename: 库文件名
## libname: 库名称
## usage:
## z_import_static_library_quiet(${find_path} ${filename} ${libname} ${deplibs})
function(z_import_static_library_quiet find_path filename libname)
    set(deplibs ${ARGN})
    set(filepath "${find_path}/${ZTARGET_ARCH}/${filename}.a")
    if (WIN32)
        set(filepath "${find_path}/${ZTARGET_ARCH}/${filename}.lib")
        if (NOT EXISTS "${filepath}")
            set(filepath "${find_path}/${ZTARGET_ARCH}/${filename}d.lib")
        endif ()
    endif ()
    if (NOT EXISTS "${filepath}")
        message(WARNING "${libname} not found: ${filepath}")
        return()
    endif ()

    add_library(${libname} STATIC IMPORTED)
    set_target_properties(${libname} PROPERTIES
            IMPORTED_LOCATION "${filepath}"
            INTERFACE_LINK_LIBRARIES "${deplibs}"
    )
    set(ZNATIVE_LIBRARIES ${ZNATIVE_LIBRARIES} ${libname})
    message(STATUS "${libname} found: ${filepath}")
endfunction()

## 导入必要的静态库
## find_path: 查找路径
## filename: 库文件名
## libname: 库名称
## usage:
## z_import_static_library_require(${find_path} ${filename} ${libname} ${deplibs})
function(z_import_static_library_require find_path filename libname)
    z_import_static_library_quiet(${find_path} ${filename} ${libname} ${ARGN})
    if (NOT TARGET ${libname})
        message(FATAL_ERROR "${libname} not found: ${filepath}")
    endif ()
endfunction()

function(z_find_opencv)
    if (ZANDROID)
        set(OpenCV_DIR ${ZZZ_PREBUILT_DIR}/opencv-4.13.0/sdk/native/jni)
    elseif (ZOHOS)
        set(OpenCV_DIR ${ZZZ_PREBUILT_DIR}/opencv-4.13.0/${OHOS_ARCH}/lib/cmake/opencv4)
    elseif (ZMACOS)
        set(OpenCV_DIR ${ZZZ_PREBUILT_DIR}/opencv-4.13.0/lib/cmake/opencv4)
        set(Eigen3_DIR ${ZZZ_PREBUILT_DIR}/eigen-3.4.0_1/share/eigen3/cmake)
        find_package(Eigen3 REQUIRED)
    elseif (ZIOS)
        set(OpenCV_DIR ${ZZZ_PREBUILT_DIR}/opencv-4.13.0/lib/cmake/opencv4)
    elseif (ZLINUX)
        message(FATAL_ERROR "TODO: not supported on linux")
    elseif (ZWINDOWS)
        set(OPENCV_LIB_PATH "${ZZZ_PREBUILT_DIR}/opencv-4.10.0")
        if (MSVC)
            if (${CMAKE_BUILD_TYPE} MATCHES "Debug")
                set(opencvtype "vc17-debug")
            else ()
                set(opencvtype "vc17-release")
            endif ()
            if (ZNATIVE_WIN32_BUILD_FOR_MT)
                set(opencvrt "MT")
                if (${CMAKE_BUILD_TYPE} MATCHES "Debug")
                    set(opencvrt "MTd")
                endif ()
            else ()
                set(opencvrt "MD")
                if (${CMAKE_BUILD_TYPE} MATCHES "Debug")
                    set(opencvrt "MDd")
                endif ()
            endif ()

            set(opencvzipname "${opencvtype}-${opencvrt}.7z")
            set(opencvdirname "${opencvtype}-${opencvrt}/${opencvtype}")
            set(OPENCV_ZIP_PATH "${OPENCV_LIB_PATH}/${opencvtype}-${opencvrt}.7z")
            set(OpenCV_DIR "${OPENCV_LIB_PATH}/${opencvtype}-${opencvrt}/${opencvtype}/x64/vc17/staticlib")
        else ()
            # MINGW
            set(OPENCV_ZIP_PATH "${OPENCV_LIB_PATH}/mingw-release.7z")
            set(OpenCV_DIR "${OPENCV_LIB_PATH}/mingw-release/x64/mingw/staticlib")
        endif ()
    else ()
        message(FATAL_ERROR "TODO: not supported on ${ZPLATFORM}")
    endif ()

    message(STATUS "OpenCV_DIR: ${OpenCV_DIR}")
    find_package(OpenCV REQUIRED)
endfunction()

list(APPEND ALL_SEARCH_LIBS "")
function(z_import_my_sub_package name)
    if (name MATCHES "\\$<LINK_ONLY:")
        string(REPLACE "\$<LINK_ONLY:" "" name ${name})
        string(REPLACE ">" "" name ${name})
    endif ()
    foreach (n : ${ALL_SEARCH_LIBS})
        if (${n} STREQUAL ${name})
            return()
        endif ()
    endforeach ()
    set(ALL_SEARCH_LIBS "${ALL_SEARCH_LIBS};${name}" PARENT_SCOPE)
    find_package(${name} QUIET)
    if (NOT TARGET ${name})
        if (${name} MATCHES "::")
            string(REPLACE "::" ";" pkgname ${name})
            foreach (pname ${pkgname})
                z_import_my_sub_package(${pname})
            endforeach ()
            if (TARGET ${name})
                message(STATUS "found library: ${name}")
            endif ()
            return()
        else ()
            message(STATUS "${name} not found")
            return()
        endif ()
    endif ()

    message(STATUS "found library: ${name}")
    if (name MATCHES "opencv")
        return()
    endif ()

    z_get_target_dep_libs(${name} depLibs)
    z_get_target_definitions(${name} definitions)

    if (depLibs STREQUAL "" OR depLibs MATCHES "NOTFOUND")
        return()
    endif ()

    message(STATUS "${name} dependencies: ${depLibs}")
    message(STATUS "${name} definitions: ${definitions}")

    if (depLibs MATCHES "opencv")
        z_find_opencv()
    endif ()

    foreach(libname ${depLibs})
        if (libname MATCHES "^/" OR libname MATCHES "^-")
            continue()
        endif ()

        if (libname MATCHES "opencv" AND "${OpenCV_LIBS}" MATCHES "opencv")
            continue()
        endif ()
        z_import_my_sub_package(${libname})
    endforeach()
endfunction()

function(z_import_my_package name)
    z_get_target_dep_libs(${name} ZZZ_DEP_LIBRARIES)
    z_get_target_definitions(${name} ZZZ_DEFINITIONS)

    if (ZZZ_DEP_LIBRARIES STREQUAL "" OR "${ZZZ_DEP_LIBRARIES}" MATCHES "NOTFOUND")
        return()
    endif ()

    message(STATUS "${name} LIBRARIES: ${ZZZ_DEP_LIBRARIES}")
    message(STATUS "${name} DEFINITIONS: ${ZZZ_DEFINITIONS}")

    if (ZZZ_DEP_LIBRARIES MATCHES "opencv")
        z_find_opencv()
    endif ()

    # 遍历 ZZZ_DEP_LIBRARIES
    foreach (libname ${ZZZ_DEP_LIBRARIES})
        if (libname MATCHES "^/" OR libname MATCHES "^-")
            continue()
        endif ()
        z_import_my_sub_package(${libname})
    endforeach ()
endfunction()

list(APPEND CMAKE_MODULE_PATH ${ZZZ_ROOT_DIR}/cmake)
find_package(@MAIN_TARGET@ REQUIRED)

z_import_my_package(@MAIN_TARGET@)

message(STATUS "========= ZZZZZ-TARGET: @MAIN_TARGET@ =========")
