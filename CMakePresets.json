{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 18,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/binary/${presetName}",
      "installDir": "${sourceDir}/build/install/${presetName}"
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "inherits": "base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "inherits": "base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "relwithdebinfo",
      "displayName": "RelWithDebInfo",
      "inherits": "base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "minisizerel",
      "displayName": "MiniSizeRel",
      "inherits": "base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "MinSizeRel"
      }
    },
    {
      "name": "host-windows",
      "hidden": true,
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "host-macos",
      "hidden": true,
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "host-linux",
      "hidden": true,
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "target-windows",
      "hidden": true,
      "inherits": "host-windows"
    },
    {
      "name": "target-x64-windows",
      "hidden": true,
      "inherits": "target-windows",
      "toolset": {
        "value": "host=x64",
        "strategy": "external"
      },
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "vendor": {
        "jetbrains.com/clion": {
          "toolchain": "Visual Studio (x64)"
        }
      }
    },
    {
      "name": "target-x86-windows",
      "hidden": true,
      "inherits": "target-windows",
      "toolset": {
        "value": "host=x86",
        "strategy": "external"
      },
      "architecture": {
        "value": "x86",
        "strategy": "external"
      },
      "vendor": {
        "jetbrains.com/clion": {
          "toolchain": "Visual Studio (x86)"
        }
      }
    },
    {
      "name": "target-arm64-windows",
      "hidden": true,
      "inherits": "target-windows",
      "toolset": {
        "value": "host=arm64",
        "strategy": "external"
      },
      "architecture": {
        "value": "arm64",
        "strategy": "external"
      },
      "vendor": {
        "jetbrains.com/clion": {
          "toolchain": "Visual Studio (ARM64)"
        }
      }
    },
    {
      "name": "target-macos",
      "hidden": true,
      "inherits": "host-macos"
    },
    {
      "name": "target-x64-macos",
      "hidden": true,
      "inherits": "target-macos",
      "cacheVariables": {
        "CMAKE_OSX_ARCHITECTURES": "x86_64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "10.15"
      }
    },
    {
      "name": "target-arm64-macos",
      "hidden": true,
      "inherits": "target-macos",
      "cacheVariables": {
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "11.0"
      }
    },
    {
      "name": "target-universal-macos",
      "hidden": true,
      "inherits": "target-macos",
      "cacheVariables": {
        "CMAKE_OSX_ARCHITECTURES": "arm64;x86_64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "11.0"
      }
    },
    {
      "name": "target-linux",
      "hidden": true,
      "inherits": "host-linux"
    },
    {
      "name": "target-x64-linux",
      "hidden": true,
      "inherits": "target-linux"
    },
    {
      "name": "target-wasm32-emscripten",
      "hidden": true,
      "cacheVariables": {
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": {
          "type": "FILEPATH",
          "value": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake"
        }
      }
    },
    {
      "name": "target-android",
      "displayName": "target-android",
      "hidden": true,
      "environment": {
        "ANDROID_NDK_HOME": "$env{ANDROID_HOME}/ndk/18.1.5063045"
      },
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
        "ANDROID_TOOLCHAIN": "clang",
        "ANDROID_PLATFORM": "android-21",
        "ANDROID_STL": "c++_shared",
        "ANDROID_ARM_NEON": {
          "type": "BOOL",
          "value": "ON"
        }
      }
    },
    {
      "name": "target-android-arm64",
      "hidden": true,
      "displayName": "target-android-arm64",
      "inherits": "target-android",
      "cacheVariables": {
        "ANDROID_ABI": "arm64-v8a"
      }
    },
    {
      "name": "target-android-armv7",
      "hidden": true,
      "displayName": "target-android-armv7",
      "inherits": "target-android",
      "cacheVariables": {
        "ANDROID_ABI": "armeabi-v7a"
      }
    },
    {
      "name": "target-harmonyos",
      "displayName": "target-harmonyos",
      "hidden": true,
      "environment": {
        "HARMONYOS_NDK_HOME": "/Applications/DevEco-Studio.app/Contents/sdk/default/openharmony/native"
      },
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{HARMONYOS_NDK_HOME}/build/cmake/ohos.toolchain.cmake",
        "OHOS_PLATFORM": "OHOS",
        "OHOS_STL": "c++_shared"
      }
    },
    {
      "name": "target-harmonyos-arm64",
      "hidden": true,
      "displayName": "target-harmonyos-arm64",
      "inherits": "target-harmonyos",
      "cacheVariables": {
        "OHOS_ARCH": "arm64-v8a"
      }
    },
    {
      "name": "target-ios",
      "hidden": true,
      "inherits": "host-macos",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "12.0"
      }
    },
    {
      "name": "target-ios-arm64",
      "hidden": true,
      "inherits": "target-ios",
      "cacheVariables": {
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_SYSTEM_PROCESSOR": "aarch64"
      }
    },
